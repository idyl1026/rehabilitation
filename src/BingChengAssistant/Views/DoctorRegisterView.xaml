<Window x:Class="BingChengAssistant.Views.DoctorRegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BingChengAssistant.ViewModels"
        Title="病程助手 v1.2 — 医生首次登记"
        Width="540" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Style="{StaticResource BaseWindow}">

    <Window.DataContext>
        <vm:DoctorRegisterViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🏥" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="病程助手 v1.2" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="首次医生登记" Foreground="#A8C4E0" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 表单 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel>
                <TextBlock Text="欢迎使用病程助手！" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="请填写您的基本信息完成登记。" Foreground="{StaticResource TextGrayBrush}"
                           FontSize="13" Margin="0,0,0,24"/>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="医生信息" Style="{StaticResource SectionTitle}"/>

                        <!-- 姓名 -->
                        <TextBlock Text="姓名 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <!-- 工号 -->
                        <TextBlock Text="工号 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding EmployeeNo, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <!-- 科室 -->
                        <TextBlock Text="科室 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <!-- 职称 -->
                        <TextBlock Text="职称" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <ComboBox Style="{StaticResource ComboBoxStyle}"
                                  Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True" Margin="0,0,0,12">
                            <ComboBoxItem>住院医师</ComboBoxItem>
                            <ComboBoxItem>主治医师</ComboBoxItem>
                            <ComboBoxItem>副主任医师</ComboBoxItem>
                            <ComboBoxItem>主任医师</ComboBoxItem>
                        </ComboBox>

                        <!-- PIN -->
                        <TextBlock Text="登录PIN（可选）" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PinBox" Margin="0,0,0,12" Padding="8,6"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     FontSize="13"/>

                        <TextBlock Text="确认PIN" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="ConfirmPinBox" Margin="0,0,0,12" Padding="8,6"
                                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                     FontSize="13"/>

                        <!-- 默认医生 -->
                        <CheckBox Content="设为默认登录医生" IsChecked="{Binding IsDefault}"
                                  FontFamily="{StaticResource DefaultFont}" Margin="0,0,0,4"/>
                    </StackPanel>
                </Border>

                <!-- 错误信息 -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                           FontSize="12" Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- 按钮 -->
                <Button Content="完成登记，进入工作台" Style="{StaticResource PrimaryButton}"
                        Command="{Binding RegisterCommand}" Margin="0,16,0,0"
                        HorizontalAlignment="Stretch" Height="42" FontSize="14"
                        Click="RegisterButton_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
