<Window x:Class="BingChengAssistant.Views.DischargeArchiveView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BingChengAssistant.ViewModels"
        Title="出院归档"
        Width="820" Height="680"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource BaseWindow}">

    <Window.DataContext>
        <vm:DischargeArchiveViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <TextBlock Text="🏠 出院归档" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左列 -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="出院信息" Style="{StaticResource SectionTitle}"/>
                            <TextBlock Text="出院日期" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding DischargeDate}" Margin="0,0,0,10"
                                        FontFamily="{StaticResource DefaultFont}" BorderBrush="{StaticResource BorderBrush}"/>
                            <TextBlock Text="出院诊断 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding DischargeDiagnosis}" Margin="0,0,0,10"/>
                            <TextBlock Text="转归" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <ComboBox Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding OutcomeOptions}"
                                      SelectedItem="{Binding DischargeOutcome}" Margin="0,0,0,10"/>
                            <TextBlock Text="出院医嘱" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding DischargeOrders}"
                                     Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                            <TextBlock Text="康复建议" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding RehabAdvice}"
                                     Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                            <TextBlock Text="随访建议" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding FollowUpAdvice}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 右列 -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="运动处方建议" Style="{StaticResource SectionTitle}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding ExercisePrescription}"
                                     Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="科研备注" Style="{StaticResource SectionTitle}"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding ResearchNote}"
                                     Height="120" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>
                            <Separator Style="{StaticResource Divider}"/>
                            <TextBlock Text="归档后将：" FontWeight="Bold" FontSize="12" Margin="0,6,0,6"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextGrayBrush}" TextWrapping="Wrap">
                                ✅ 标记患者状态为"已归档"&#x0a;✅ 生成出院归档 Word 文档&#x0a;✅ 更新科研索引 Excel
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 错误信息 -->
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                               FontSize="12" Margin="0,8,0,0"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,10,0" IsCancel="True"/>
                <Button Content="生成Word并归档" Style="{StaticResource PrimaryButton}" Width="140"
                        Command="{Binding ArchiveCommand}" Click="ArchiveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
