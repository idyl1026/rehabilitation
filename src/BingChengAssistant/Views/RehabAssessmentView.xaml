<Window x:Class="BingChengAssistant.Views.RehabAssessmentView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BingChengAssistant.ViewModels"
        Title="康复评估"
        Width="960" Height="660"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource BaseWindow}">

    <Window.DataContext>
        <vm:RehabAssessmentViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="康复评估" Foreground="White" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Foreground="#A8C4E0" FontSize="13" VerticalAlignment="Center">
                    <Run Text="{Binding Admission.Patient.Name, FallbackValue=''}"/>
                    <Run Text="  "/>
                    <Run Text="{Binding Admission.MainDiagnosis, FallbackValue=''}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- 左列：量表列表 -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,4,0" Padding="0">
                <StackPanel>
                    <Border Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="评估量表" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>
                    <ListBox ItemsSource="{Binding Scales}"
                             SelectedItem="{Binding SelectedScale}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="{StaticResource TextGrayBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- 中列：评估表单 -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,4,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{Binding SelectedScale.Name, FallbackValue='请从左侧选择量表'}"
                                   Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="{Binding SelectedScale.Description}" FontSize="12"
                                   Foreground="{StaticResource TextGrayBrush}" TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <!-- VAS / NRS -->
                        <StackPanel Visibility="{Binding IsVasNrs, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="疼痛评分（0-10分）" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Slider Minimum="0" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding VasNrsScore}" TickPlacement="BottomRight" Margin="0,0,0,8"/>
                            <Border Background="#EEF4FF" CornerRadius="6" Padding="16,12" Margin="0,0,0,12">
                                <TextBlock FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource PrimaryBlueBrush}">
                                    <Run Text="{Binding VasNrsScore}"/>
                                    <Run Text=" 分"/>
                                </TextBlock>
                            </Border>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="0=无痛" FontSize="11" Foreground="{StaticResource SuccessBrush}" Margin="0,0,16,0"/>
                                <TextBlock Text="1-3=轻度" FontSize="11" Foreground="{StaticResource TextGrayBrush}" Margin="0,0,16,0"/>
                                <TextBlock Text="4-6=中度" FontSize="11" Foreground="{StaticResource WarningBrush}" Margin="0,0,16,0"/>
                                <TextBlock Text="7-10=重度" FontSize="11" Foreground="{StaticResource DangerBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- MMT -->
                        <StackPanel Visibility="{Binding IsMmt, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="肌群名称" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding MmtMuscle}" Margin="0,0,0,12"/>
                            <TextBlock Text="肌力等级（0-5级）" Style="{StaticResource FieldLabel}" Margin="0,0,0,8"/>
                            <Slider Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding MmtGrade}" TickPlacement="BottomRight" Margin="0,0,0,8"/>
                            <Border Background="#EEF4FF" CornerRadius="6" Padding="16,12" Margin="0,0,0,12">
                                <TextBlock FontSize="32" FontWeight="Bold" HorizontalAlignment="Center"
                                           Foreground="{StaticResource PrimaryBlueBrush}">
                                    <Run Text="{Binding MmtGrade}"/>
                                    <Run Text=" 级"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- ROM -->
                        <StackPanel Visibility="{Binding IsRom, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="关节名称" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding RomJoint}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="运动方向" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding RomDirection}"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="主动活动度(°)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding RomActive}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="被动活动度(°)" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                    <TextBox Style="{StaticResource InputBox}" Text="{Binding RomPassive}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="疼痛情况" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding RomPain}" Margin="0,0,0,10"/>
                            <TextBlock Text="备注" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource InputBox}" Text="{Binding RomRemark}"
                                     Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>

                        <Button Content="计算 / 生成解释" Style="{StaticResource PrimaryButton}"
                                Margin="0,16,0,0" HorizontalAlignment="Left"
                                Command="{Binding CalcCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右列：结果卡片 -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="4,0,0,0">
                <StackPanel>
                    <TextBlock Text="评估结果" Style="{StaticResource SectionTitle}"/>

                    <!-- 评分结果大字显示 -->
                    <Border Background="#EEF4FF" CornerRadius="6" Padding="14,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="评分结果" FontSize="11" Foreground="{StaticResource TextGrayBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ResultSummary, FallbackValue='—'}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBlueBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="解释" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Interpretation}" FontSize="13" TextWrapping="Wrap"
                               Foreground="{StaticResource TextDarkBrush}" Margin="0,0,0,10"/>

                    <TextBlock Text="康复建议" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Advice}" FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextGrayBrush}" Margin="0,0,0,12"/>

                    <Separator Style="{StaticResource Divider}"/>

                    <TextBlock Text="导入病程文本预览" Style="{StaticResource FieldLabel}" Margin="0,6,0,4"/>
                    <Border Background="#F8FAFC" CornerRadius="4" Padding="8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                        <TextBlock Text="{Binding NoteText}" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource TextDarkBrush}" MaxHeight="120"/>
                    </Border>
                    <Button Content="复制导入文本" Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Stretch" Padding="10,6"
                            Command="{Binding CopyNoteCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}"
                        Width="80" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="计算评分" Style="{StaticResource SecondaryButton}"
                        Padding="12,8" Margin="0,0,8,0"
                        Command="{Binding CalcCommand}"/>
                <Button Content="导入病程" Style="{StaticResource SecondaryButton}"
                        Padding="12,8" Margin="0,0,8,0"
                        Command="{Binding CopyNoteCommand}"/>
                <Button Content="保存评估" Style="{StaticResource PrimaryButton}" Width="110"
                        Command="{Binding SaveCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
