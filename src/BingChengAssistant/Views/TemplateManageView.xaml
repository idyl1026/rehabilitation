<Window x:Class="BingChengAssistant.Views.TemplateManageView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="模板管理"
        Width="900" Height="640"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource BaseWindow}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <TextBlock Text="病程模板管理" Foreground="White" FontSize="15" FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </Border>

        <Grid Grid.Row="1" Margin="8,8,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左：模板列表 -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="模板列表" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource TextDarkBrush}" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <Border Background="#EEF4FF" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding NoteType}" FontSize="10"
                                                           Foreground="{StaticResource PrimaryBlueBrush}"/>
                                            </Border>
                                            <Border Background="#F0FFF4" CornerRadius="2" Padding="4,1"
                                                    Visibility="{Binding IsBuiltIn, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="内置" FontSize="10" Foreground="{StaticResource SuccessBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                    <Button Grid.Row="2" Content="+ 新建模板" Style="{StaticResource PrimaryButton}"
                            Margin="8,6,8,8" HorizontalAlignment="Stretch" Padding="10,7"
                            Command="{Binding NewCommand}"/>
                </Grid>
            </Border>

            <!-- 右：编辑区 -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="编辑模板" Style="{StaticResource SectionTitle}"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="模板名称 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="病程类型" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource ComboBoxStyle}"
                                          ItemsSource="{Binding NoteTypes}"
                                          SelectedItem="{Binding EditNoteType}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="模板内容（支持变量：{姓名} {年龄} {主要诊断} {入院日期} {今日日期} {医生姓名}）"
                                   Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Style="{StaticResource InputBox}"
                             Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Microsoft YaHei UI"
                             FontSize="12" Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" Margin="0,0,0,6"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="删除模板" Style="{StaticResource DangerButton}"
                                    Width="90" Margin="0,0,8,0" Command="{Binding DeleteCommand}"/>
                            <Button Content="保存模板" Style="{StaticResource PrimaryButton}"
                                    Width="110" Command="{Binding SaveCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
