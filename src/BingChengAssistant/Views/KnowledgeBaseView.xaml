<Window x:Class="BingChengAssistant.Views.KnowledgeBaseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="知识库管理"
        Width="1000" Height="680"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource BaseWindow}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="知识库管理" Foreground="White" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="录入科室专科知识，病程书写时可引用" Foreground="#A8C4E0" FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="8,8,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左列：列表 + 搜索 -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="知识条目" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>

                    <TextBox Grid.Row="1" Style="{StaticResource InputBox}" Margin="8,6,8,4"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource InputBox}"/>
                        </TextBox.Resources>
                    </TextBox>

                    <ListBox Grid.Row="2" ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource TextDarkBrush}" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <Border Background="#EEF4FF" CornerRadius="2" Padding="4,1" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding Category}" FontSize="10"
                                                           Foreground="{StaticResource PrimaryBlueBrush}"/>
                                            </Border>
                                            <TextBlock Text="{Binding Tags}" FontSize="10"
                                                       Foreground="{StaticResource TextGrayBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <StackPanel Grid.Row="3" Margin="8,6,8,8">
                        <Button Content="+ 新增条目" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Stretch" Padding="10,7" Margin="0,0,0,6"
                                Command="{Binding NewCommand}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="导入Excel" Style="{StaticResource SecondaryButton}"
                                    Padding="6,6" FontSize="12" Margin="0,0,3,0"
                                    Click="ImportExcel_Click"/>
                            <Button Grid.Column="1" Content="下载模板" Style="{StaticResource SecondaryButton}"
                                    Padding="6,6" FontSize="12" Margin="3,0,0,0"
                                    Click="ExportTemplate_Click"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右列：编辑区 -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="编辑知识条目" Style="{StaticResource SectionTitle}"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="标题 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="分类" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource ComboBoxStyle}"
                                          ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding EditCategory}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="关键词标签（逗号分隔）" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding EditTags}" Margin="0,0,0,10"/>

                        <TextBlock Text="知识内容 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Style="{StaticResource InputBox}"
                             Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="13" Margin="0,0,0,8"/>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" Margin="0,0,0,6"
                                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="删除" Style="{StaticResource DangerButton}"
                                    Width="80" Margin="0,0,8,0" Command="{Binding DeleteCommand}"/>
                            <Button Content="清除" Style="{StaticResource SecondaryButton}"
                                    Width="80" Margin="0,0,8,0" Command="{Binding ClearCommand}"/>
                            <Button Content="保存条目" Style="{StaticResource PrimaryButton}"
                                    Width="120" Command="{Binding SaveCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
