<Window x:Class="BingChengAssistant.Views.MainWorkbenchView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BingChengAssistant.ViewModels"
        Title="病程助手 v1.2"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource BaseWindow}">

    <Window.DataContext>
        <vm:MainWorkbenchViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ── 顶部标题栏 ── -->
        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🏥 病程助手 v1.2" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" — " Foreground="#5B8DB8" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DoctorInfo}" Foreground="#A8C4E0" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button Content="⚙ 设置" Style="{StaticResource SecondaryButton}"
                            Padding="10,4" FontSize="12" Background="Transparent"
                            Foreground="White" BorderBrush="#5B8DB8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 主体三列 ── -->
        <Grid Grid.Row="1" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- ── 左列：患者列表 ── -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 标题 -->
                    <Border Grid.Row="0" Padding="12,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="患者工作台" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>

                    <!-- 搜索 -->
                    <TextBox Grid.Row="1" Style="{StaticResource InputBox}"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Margin="8,8,8,4"
                             xml:space="preserve"/>

                    <!-- 状态筛选 -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8,2,8,4">
                        <RadioButton Content="全部" IsChecked="True" Margin="0,0,6,0"
                                     FontSize="12" FontFamily="{StaticResource DefaultFont}"
                                     Command="{Binding DataContext.NewPatientCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                     Checked="StatusFilter_Checked" Tag=""/>
                        <RadioButton Content="在院" Margin="0,0,6,0" FontSize="12"
                                     FontFamily="{StaticResource DefaultFont}"
                                     Checked="StatusFilter_Checked" Tag="在院"/>
                        <RadioButton Content="已出院" Margin="0,0,6,0" FontSize="12"
                                     FontFamily="{StaticResource DefaultFont}"
                                     Checked="StatusFilter_Checked" Tag="已出院"/>
                        <RadioButton Content="归档" FontSize="12"
                                     FontFamily="{StaticResource DefaultFont}"
                                     Checked="StatusFilter_Checked" Tag="已归档"/>
                    </StackPanel>

                    <!-- 患者列表 -->
                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding Admissions}"
                             SelectedItem="{Binding SelectedAdmission}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Patient.Name}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{StaticResource TextDarkBrush}"/>
                                            <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}">
                                                <TextBlock Text="{Binding Status}" FontSize="10" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding BedNo, StringFormat='{}🛏 {0}床'}" FontSize="11"
                                                   Foreground="{StaticResource TextGrayBrush}" Margin="0,1,0,0"/>
                                        <TextBlock Text="{Binding MainDiagnosis}" FontSize="11"
                                                   Foreground="{StaticResource TextGrayBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding AdmissionDate, StringFormat='{}入院 {0:MM-dd}'}"
                                                   FontSize="10" Foreground="#9BAFC0" Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- 底部按钮 -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="8,6,8,8">
                        <Button Content="+ 新建患者" Style="{StaticResource PrimaryButton}"
                                Padding="10,6" FontSize="12"
                                Command="{Binding NewPatientCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── 中列：病程记录 ── -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 患者摘要栏 -->
                    <Border Grid.Row="0" Background="#EEF4FF" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextDarkBrush}">
                                    <Run Text="{Binding SelectedAdmission.Patient.Name, FallbackValue='请从左侧选择患者'}"/>
                                    <Run Text="  "/>
                                    <Run Text="{Binding SelectedAdmission.Patient.Gender, FallbackValue=''}" Foreground="{StaticResource TextGrayBrush}" FontSize="12"/>
                                    <Run Text="{Binding SelectedAdmission.Patient.Age, FallbackValue='', StringFormat='{}{0}岁'}" Foreground="{StaticResource TextGrayBrush}" FontSize="12"/>
                                </TextBlock>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextGrayBrush}" Margin="0,2,0,0">
                                    <Run Text="{Binding SelectedAdmission.MainDiagnosis, FallbackValue=''}"/>
                                    <Run Text="   住院号："/>
                                    <Run Text="{Binding SelectedAdmission.AdmissionNo, FallbackValue=''}"/>
                                    <Run Text="   床号："/>
                                    <Run Text="{Binding SelectedAdmission.BedNo, FallbackValue=''}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 工具栏 -->
                    <Border Grid.Row="1" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="✏ 新建病程" Style="{StaticResource PrimaryButton}"
                                    Padding="12,6" FontSize="12" Margin="0,0,8,0"
                                    Command="{Binding NewNoteCommand}"/>
                            <Button Content="📋 患者档案" Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" FontSize="12" Margin="0,0,8,0"
                                    Command="{Binding EditPatientCommand}"/>
                            <Button Content="🩺 康复评估" Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" FontSize="12" Margin="0,0,8,0"
                                    Command="{Binding RehabCommand}"/>
                            <Button Content="🏠 出院归档" Style="{StaticResource DangerButton}"
                                    Padding="10,6" FontSize="12" Margin="0,0,8,0"
                                    Command="{Binding DischargeCommand}"/>
                            <Button Content="📂 打开目录" Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" FontSize="12" Margin="0,0,8,0"
                                    Command="{Binding OpenDirCommand}"/>
                            <Button Content="📄 Word" Style="{StaticResource SecondaryButton}"
                                    Padding="10,6" FontSize="12"
                                    Command="{Binding OpenWordCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- 病程历史标题 -->
                    <TextBlock Grid.Row="2" Text="病程历史记录（双击编辑）"
                               FontWeight="Bold" FontSize="13" Margin="12,10,12,6"
                               Foreground="{StaticResource TextDarkBrush}"/>

                    <!-- 病程列表 -->
                    <ListView Grid.Row="3"
                              ItemsSource="{Binding Notes}"
                              BorderThickness="0" Background="Transparent"
                              Margin="8,0,8,0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="日期" Width="130"
                                    DisplayMemberBinding="{Binding RecordDate, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                <GridViewColumn Header="类型" Width="90"
                                    DisplayMemberBinding="{Binding NoteType}"/>
                                <GridViewColumn Header="内容摘要" Width="300"
                                    DisplayMemberBinding="{Binding Content}"/>
                                <GridViewColumn Header="同步" Width="50"
                                    DisplayMemberBinding="{Binding IsSyncedToWord, Converter={StaticResource BoolToYesNoConverter}}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- 底部统计 -->
                    <Border Grid.Row="4" Background="#F8FAFC" Padding="12,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12" Foreground="{StaticResource TextGrayBrush}">
                                <Run Text="在院 "/>
                                <Run Text="{Binding InHospitalCount}" FontWeight="Bold" Foreground="{StaticResource PrimaryBlueBrush}"/>
                                <Run Text="  已出院 "/>
                                <Run Text="{Binding DischargedCount}" FontWeight="Bold" Foreground="{StaticResource TextGrayBrush}"/>
                                <Run Text="  已归档 "/>
                                <Run Text="{Binding ArchivedCount}" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── 右列：推荐与评估 ── -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="4,0,0,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="⚡ 康复评估记录" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>

                    <TextBlock Grid.Row="1" Text="当前患者最近评估" Foreground="{StaticResource TextGrayBrush}"
                               FontSize="11" Margin="12,6,12,2"/>

                    <ListView Grid.Row="2"
                              ItemsSource="{Binding Rehabs}"
                              BorderThickness="0" Background="Transparent"
                              Margin="4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" Margin="0,2" BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ScaleName}" FontWeight="Bold" FontSize="12"
                                                   Foreground="{StaticResource PrimaryBlueBrush}"/>
                                        <TextBlock Text="{Binding ResultSummary}" FontSize="12"
                                                   Foreground="{StaticResource TextDarkBrush}"/>
                                        <TextBlock Text="{Binding AssessmentDate, StringFormat='yyyy-MM-dd'}"
                                                   FontSize="10" Foreground="{StaticResource TextGrayBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ── 底部状态栏 ── -->
        <Border Grid.Row="2" Background="#E8EEF4" Padding="12,0">
            <TextBlock Text="病程助手 v1.2  |  内网单机版  |  仅用于辅助病程书写，不替代正式电子病历系统"
                       FontSize="11" Foreground="{StaticResource TextGrayBrush}" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
