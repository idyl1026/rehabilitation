<Window x:Class="BingChengAssistant.Views.PatientEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BingChengAssistant.ViewModels"
        Title="患者档案"
        Width="700" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Style="{StaticResource BaseWindow}">

    <Window.DataContext>
        <vm:PatientEditViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <TextBlock Text="患者档案" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <!-- 基本信息 -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="基本信息" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="姓名 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                <TextBlock Text="年龄" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                                <TextBlock Text="联系电话" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="性别" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource ComboBoxStyle}" SelectedItem="{Binding Gender}" Margin="0,0,0,10">
                                    <ComboBoxItem>男</ComboBoxItem>
                                    <ComboBoxItem>女</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Text="过敏史" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding AllergyHistory}" Margin="0,0,0,10"/>
                                <TextBlock Text="既往史" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding PastHistory}" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 住院信息 -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="住院信息" Style="{StaticResource SectionTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="住院号" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding AdmissionNo}" Margin="0,0,0,10"/>
                                <TextBlock Text="入院日期 *" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <DatePicker SelectedDate="{Binding AdmissionDate}" FontFamily="{StaticResource DefaultFont}"
                                            BorderBrush="{StaticResource BorderBrush}" Margin="0,0,0,10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                <TextBlock Text="床号" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding BedNo}" Margin="0,0,0,10"/>
                                <TextBlock Text="科室" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding Department}" Margin="0,0,0,10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="医保类型" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <ComboBox Style="{StaticResource ComboBoxStyle}" SelectedItem="{Binding InsuranceType}" IsEditable="True" Margin="0,0,0,10">
                                    <ComboBoxItem>职工医保</ComboBoxItem>
                                    <ComboBoxItem>居民医保</ComboBoxItem>
                                    <ComboBoxItem>自费</ComboBoxItem>
                                    <ComboBoxItem>商业保险</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Text="参保地" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputBox}" Text="{Binding InsuranceRegion}" Margin="0,0,0,10"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="主要诊断 *" Style="{StaticResource FieldLabel}" Margin="0,4,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding MainDiagnosis}" Margin="0,0,0,10"/>
                        <TextBlock Text="次要诊断" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource InputBox}" Text="{Binding SecondaryDiagnosis}"/>
                    </StackPanel>
                </Border>

                <!-- 错误信息 -->
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"
                           FontSize="12" Margin="0,8,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,10,0" IsCancel="True"/>
                <Button Content="保存档案" Style="{StaticResource PrimaryButton}" Width="110"
                        Command="{Binding SaveCommand}" Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
