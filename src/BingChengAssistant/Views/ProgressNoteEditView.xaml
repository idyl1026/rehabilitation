<Window x:Class="BingChengAssistant.Views.ProgressNoteEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BingChengAssistant.ViewModels"
        Title="新建病程记录"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource BaseWindow}">

    <Window.DataContext>
        <vm:ProgressNoteEditViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="新建病程记录" Foreground="White" FontSize="15" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 患者信息栏（蓝色背景） -->
                    <Border Background="#1F4A80" CornerRadius="4" Padding="10,4">
                        <TextBlock Foreground="#A8C4E0" FontSize="13">
                            <Run Text="{Binding Admission.Patient.Name, FallbackValue=''}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding Admission.Patient.Gender, FallbackValue=''}"/>
                            <Run Text="{Binding Admission.Patient.Age, FallbackValue='', StringFormat='{}{0}岁'}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding Admission.MainDiagnosis, FallbackValue=''}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主体三列 -->
        <Grid Grid.Row="1" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 左列：模板列表 -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="选择模板" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="10,8,10,4">
                        <TextBlock Text="病程类型" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <ComboBox Style="{StaticResource ComboBoxStyle}"
                                  ItemsSource="{Binding NoteTypes}"
                                  SelectedItem="{Binding NoteType}"/>
                    </StackPanel>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,7" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource TextDarkBrush}" TextWrapping="Wrap"/>
                                        <Border Background="#EEF4FF" CornerRadius="2" Padding="4,1"
                                                HorizontalAlignment="Left" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding NoteType}" FontSize="10"
                                                       Foreground="{StaticResource PrimaryBlueBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 中列：编辑器 -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 工具栏 -->
                    <Border Grid.Row="0" Padding="12,8" Background="#F8FAFC"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="病程内容" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextDarkBrush}"/>
                            <TextBlock Grid.Column="1" FontSize="11" Foreground="{StaticResource TextGrayBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="已输入 "/>
                                <Run Text="{Binding Content.Length}"/>
                                <Run Text=" 字"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <TextBox Grid.Row="1"
                             Style="{StaticResource InputBox}"
                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Microsoft YaHei UI, Consolas"
                             FontSize="13"
                             BorderThickness="0"
                             Margin="2"/>
                </Grid>
            </Border>

            <!-- 右列：知识卡片与推荐 -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="4,0,0,0" Padding="0">
                <StackPanel>
                    <Border Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="快捷操作" FontWeight="Bold" FontSize="13"
                                   Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>
                    <StackPanel Margin="10,10">
                        <Button Content="复制到剪贴板" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8" Padding="10,7"
                                Command="{Binding CopyCommand}"/>
                        <Button Content="同步到Word" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Padding="10,7"
                                Command="{Binding SyncWordCommand}"/>
                        <Separator Style="{StaticResource Divider}"/>
                        <TextBlock Text="知识卡片参考" FontWeight="Bold" FontSize="12"
                                   Margin="0,4,0,8" Foreground="{StaticResource TextDarkBrush}"/>
                        <Border Background="#F8FAFC" CornerRadius="4" Padding="8,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <TextBlock Text="根据患者诊断，智能推荐相关知识内容（后续版本实现）"
                                       FontSize="11" Foreground="{StaticResource TextGrayBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                        <Separator Style="{StaticResource Divider}"/>
                        <TextBlock Text="推荐内容" FontWeight="Bold" FontSize="12"
                                   Margin="0,4,0,8" Foreground="{StaticResource TextDarkBrush}"/>
                        <Border Background="#F8FAFC" CornerRadius="4" Padding="8,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <TextBlock Text="智能推荐相关治疗方案（后续版本实现）"
                                       FontSize="11" Foreground="{StaticResource TextGrayBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}"
                        Width="80" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="复制到电子病历" Style="{StaticResource SecondaryButton}"
                        Padding="12,8" Margin="0,0,8,0" Command="{Binding CopyCommand}"/>
                <Button Content="同步Word" Style="{StaticResource SecondaryButton}"
                        Padding="12,8" Margin="0,0,8,0" Command="{Binding SyncWordCommand}"/>
                <Button Content="确认保存" Style="{StaticResource PrimaryButton}" Width="110"
                        Command="{Binding SaveCommand}" Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
