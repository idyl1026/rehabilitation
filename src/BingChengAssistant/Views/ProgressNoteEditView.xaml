<Window x:Class="BingChengAssistant.Views.ProgressNoteEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BingChengAssistant.ViewModels"
        Title="新建病程记录"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource BaseWindow}">

    <Window.DataContext>
        <vm:ProgressNoteEditViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Style="{StaticResource HeaderPanel}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="✏ 新建病程记录" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <TextBlock VerticalAlignment="Center" Foreground="#A8C4E0" FontSize="13">
                    <Run Text="{Binding Admission.Patient.Name, FallbackValue=''}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding Admission.MainDiagnosis, FallbackValue=''}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 主体三列 -->
        <Grid Grid.Row="1" Margin="8,8,8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 左：模板列表 -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="选择模板" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="10,8,10,4">
                        <TextBlock Text="病程类型" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                        <ComboBox Style="{StaticResource ComboBoxStyle}"
                                  ItemsSource="{Binding NoteTypes}"
                                  SelectedItem="{Binding NoteType}"/>
                    </StackPanel>
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Templates}"
                             SelectedItem="{Binding SelectedTemplate}"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{StaticResource TextDarkBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding NoteType}" FontSize="10"
                                                   Foreground="{StaticResource TextGrayBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 中：编辑器 -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,4,0" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,8" Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="病程内容" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,16,0"/>
                            <TextBlock Text="{Binding Content.Length, StringFormat='{}已输入 {0} 字'}"
                                       FontSize="11" Foreground="{StaticResource TextGrayBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <TextBox Grid.Row="1"
                             Style="{StaticResource InputBox}"
                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             FontFamily="Microsoft YaHei UI, Consolas"
                             FontSize="13"
                             BorderThickness="0"
                             Margin="2"/>
                </Grid>
            </Border>

            <!-- 右：推荐内容 -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Margin="4,0,0,0" Padding="0">
                <StackPanel>
                    <Border Padding="10,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="⚡ 快捷操作" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextDarkBrush}"/>
                    </Border>
                    <StackPanel Margin="10,12">
                        <Button Content="📋 复制到剪贴板" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8" Padding="10,7"
                                Command="{Binding CopyCommand}"/>
                        <Button Content="📄 同步到Word" Style="{StaticResource SecondaryButton}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8" Padding="10,7"
                                Command="{Binding SyncWordCommand}"/>
                        <Separator Style="{StaticResource Divider}"/>
                        <TextBlock Text="推荐模板" FontWeight="Bold" FontSize="12" Margin="0,4,0,6" Foreground="{StaticResource TextDarkBrush}"/>
                        <TextBlock Text="（根据诊断智能推荐，后续版本实现）"
                                   FontSize="11" Foreground="{StaticResource TextGrayBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,10,0" IsCancel="True"/>
                <Button Content="保存病程" Style="{StaticResource PrimaryButton}" Width="110"
                        Command="{Binding SaveCommand}" Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
